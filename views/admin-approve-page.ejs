<!doctype ejs>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <title>Admin - Aprovar Comprovantes</title>

  <link href="/bootstrap/css/bootstrap.min.css" rel="stylesheet">
  <script src="/sweetalert/sweetalert2.min.js"></script>
  <link rel="stylesheet" href="/sweetalert/sweetalert2.min.css">
</head>

<body class="bg-light">
  <table class="table">
  <thead>
    <tr>
      <th>Nome</th>
      <th>CPF</th>
      <th>Ações</th>
    </tr>
  </thead>
  <tbody>
    <% pendentes.forEach(p => { %>
      <tr>
        <td><%= p.user.nome %></td>
        <td><%= p.user.cpf %></td>
        <td>
          <a href="/download/<%= p.fileId %>" class="btn btn-sm btn-secondary">Download</a>

          <form method="post" action="/admin/approve" class="d-inline">
            <input type="hidden" name="uploadId" value="<%= p._id %>">
            <input type="hidden" name="userId" value="<%= p.user._id %>">
            <button class="btn btn-sm btn-success">Aprovar</button>
          </form>
        </td>
      </tr>
    <% }) %>
  </tbody>
</table>

</body>
</html>
