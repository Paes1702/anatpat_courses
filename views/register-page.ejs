<html lang="en">

<style>
    html, body {
        height: 100%;
    }

    body {
        display: flex;
        background: url("assets/unicamp-blur.jpg") no-repeat center center fixed; 
        -webkit-background-size: cover;
        -moz-background-size: cover;
        -o-background-size: cover;
        background-size: cover;
    }

    .form-signin {
        width: 100%;
        max-width: 60%;
        min-width: 330px;
        padding: 20px;
        margin: auto;
    }

    .card {
        border-radius: 10px;
    }

    .form-signin .form-floating:focus-within {
        z-index: 2;
    }
</style>

<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
