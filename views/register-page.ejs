    <script>

        function showTerms() {
            let text =  "Este site precisa utilizar as seguintes informações pessoais "
            text +=     "para cadatrá-lo no Curso Uropatologia 2024 "
            text +=     "2022 online:\n\n"
            text +=     "- Nome Completo\n"
            text +=     "- Número de RG\n"
            text +=     "- Número de CPF\n"
            text +=     "- Endereço Residêncial\n"
            text +=     "- Telefones\n\n"
            text +=     "A partir de sua aprovação, a aplicação mencionada acima "
            text +=     "permitirá que o Curso de Uropatologia 2024 "
            text +=     "2022 utilize as informações acima, respeitando os termos  de "
            text +=     "uso e a politica de privacidade, segundo a Lei Geral de Proteção "
            text +=     "de Dados Pessoais (LGPD).\n\n"
            text +=     "http://www.planalto.gov.br/ccivil_03/_Ato2015-2018/2018/Lei/L13709compilado.htm"
            swal({
                title: "Termos de contrato",
                text: text,
                icon: "info",
                button: "Fechar",
            });
        }

