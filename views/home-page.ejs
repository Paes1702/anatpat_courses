<!doctype html>
<html lang="en">

<style>
    html, body {
        height: 100%;
    }

    body {
        display: flex;
        background: url('/assets/unicamp-blur.jpg') no-repeat center center fixed;
        -webkit-background-size: cover;
        -moz-background-size: cover;
        -o-background-size: cover;
        background-size: cover;
    }

    .form-signin {
        width: 100%;
        max-width: 35%;
        min-width: 330px;
        padding: 20px;
        margin: auto;
    }


    .card {
        border-radius: 10px;
    }

    .form-signin .form-floating:focus-within {
        z-index: 2;
    }
</style>

<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Homepage</title>

    <link href="/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <script src="/bootstrap/js/bootstrap.bundle.min.js" rel="stylesheet"></script>

    <script src="/sweetalert/sweetalert2.min.js"></script>
    <link rel="stylesheet" href="/sweetalert/sweetalert2.min.css">

    <script src="/inputmask/inputmask.min.js"></script>
    
</head>
<body>
    <main class="form-signin card shadow">
        <div class="row gx-3 gy-3">
            <div class="text-center col-12">
                    <h5>Curso Uropatologia <%= new Date().getFullYear(); %></h5>
                    <h5></h5>
            </div>
            <div class="col-12">
              <div class="row gx-0 gy-2">
                    <div class="col-12 text-center fs-5">
                        Depósito bancário
                    </div>
                    <div class="col-12">
                        <table class="table table-hover table-bordered mb-0">
                            <thead>
                                <tr>
                                    <th scope="col">Banco</th>
                                    <th scope="col">Agência</th>
                                    <th scope="col">Tipo</th>
                                    <th scole="col">Número</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>Santander</th>
                                    <td>0207</td>
                                    <td>Corrente</td>
                                    <td>01-071252-1</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <div class="col-12 text-center fs-5">
                        PIX: patologiacurso@gmail.com
                    </div>
                </div>
            </div>

            <form action="/upload" method="post" enctype="multipart/form-data">
                <h5 class="text-start">Enviar comprovante de pagamento</h5>

                <input
                    class="form-control"
                    type="file"
                    name="payment_voucher"
                    accept="image/*,application/pdf"
                    required
                />

                <button class="w-100 btn btn-lg btn-outline-primary mt-3" type="submit">
                    Enviar Comprovante
                </button>
            </form>
            <form action="/homepage/logout" method="post">
                <button class="w-100 btn btn-lg btn-outline-danger" type="submit">Sair</button>
            </form>
        </div>
    </main>
    <% if(typeof error !== 'undefined') { %>
        <script>
            document.addEventListener("DOMContentLoaded", () => {
                Swal.fire({
                    title: "Erro!",
                    text: "<%= error %>",
                    icon: "error",
                    showConfirmButton: true
                })
            })
        </script>
    <% } %>
    <% if(typeof success !== 'undefined') { %>
        <script>
            document.addEventListener("DOMContentLoaded", () => {
                Swal.fire({
                    title: "Sucesso!",
                    text: "<%= success %>",
                    icon: "success",
                    showConfirmButton: true
                })
            })
        </script>
    <% } %>
</body>
</html>