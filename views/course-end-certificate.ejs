<!doctype html>
<html lang="en">

<style>
html, body {
    height: 100%;
}

body {
    display: flex;
    background: url('/assets/unicamp-blur.jpg') no-repeat center center fixed;
    background-size: cover;
}

.form-signin {
    width: 100%;
    max-width: 600px;
    min-width: 330px;
    padding: 30px;
    margin: auto;
}

.card {
    border-radius: 12px;
}

#countdown h2 {
    font-size: 2.8rem;
}

#countdown .card {
    background: rgba(255,255,255,0.9);
}
</style>

<head>
<meta charset="utf-8">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Curso Finalizado</title>

<link href="/bootstrap/css/bootstrap.min.css" rel="stylesheet">
<script src="/bootstrap/js/bootstrap.bundle.min.js"></script>

<script src="/sweetalert/sweetalert2.min.js"></script>
<link rel="stylesheet" href="/sweetalert/sweetalert2.min.css">

<script src="/inputmask/inputmask.min.js"></script>

</head>

<body>

<main class="form-signin card shadow-lg">

<div class="text-center mb-4">

<h3 class="fw-bold">Curso de Patologia <%= new Date().getFullYear() %></h3>

<p class="text-muted mb-0">
O curso ainda já foi finalizado, clique no botão abaixo para gerar seu certificado.
</p>

</div>

<div class="d-grid gap-3 mt-4">
    <a href="/certificate" class="btn btn-outline-primary">Ir para certificado</a>
</div>

<hr class="my-4">

<form action="/homepage/logout" method="post">
<button class="w-100 btn btn-lg btn-outline-danger" type="submit">
Sair
</button>
</form>

</main>

<% if(typeof error !== 'undefined') { %>
<script>
document.addEventListener("DOMContentLoaded", () => {
Swal.fire({
title: "Erro!",
text: "<%= error %>",
icon: "error",
showConfirmButton: true
})
})
</script>
<% } %>

<% if(typeof success !== 'undefined') { %>
<script>
document.addEventListener("DOMContentLoaded", () => {
Swal.fire({
title: "Sucesso!",
text: "<%= success %>",
icon: "success",
showConfirmButton: true
})
})
</script>
<% } %>

</body>
</html>