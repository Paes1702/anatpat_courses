<!doctype html>
<html lang="pt-br">
<style>
  body {
      background: url('<%= basePath %>/assets/unicamp-blur.jpg') no-repeat center center fixed;
      -webkit-background-size: cover;
      -moz-background-size: cover;
      -o-background-size: cover;
      background-size: cover;
  }
</style>
<head>
  <meta charset="UTF-8">
  <title>Admin - Promover Usuário</title>

  <link href="<%= basePath %>/bootstrap/css/bootstrap.min.css" rel="stylesheet">
  <script src="<%= basePath %>/bootstrap/js/bootstrap.bundle.min.js" rel="stylesheet"></script>  

  <script src="<%= basePath %>/sweetalert/sweetalert2.min.js"></script>
  <link rel="stylesheet" href="<%= basePath %>/sweetalert/sweetalert2.min.css">

  <script src="<%= basePath %>/inputmask/inputmask.min.js"></script>
</head>

<body>
    <main class="container d-flex justify-content-center align-items-center vh-100">
        <div class="card p-4 shadow" style="max-width: 500px; width: 100%;">
            <h4 class="text-center mb-3">Promover Administrador</h4>

            <form action="<%= basePath %>/admin/promote/search" method="post">
            <div class="mb-3">
                <label class="form-label" for="cpf">CPF do usuário</label>
                <input 
                type="text"
                name="cpf"
                id="cpf"
                class="form-control"
                placeholder="CPF"
                required
                >
            </div>
            <button class="btn btn-outline-primary w-100">
                Buscar usuário
            </button>
            </form>

            <% if (user) { %>
                <hr>

                <h5>Dados do usuário</h5>
                <ul class="list-group mb-3">
                    <li class="list-group-item"><strong>Nome:</strong> <%= user.nome %></li>
                    <li class="list-group-item"><strong>Email:</strong> <%= user.email %></li>
                    <li class="list-group-item"><strong>CPF:</strong> <%= user.cpf %></li>
                    <li class="list-group-item">
                    <strong>Status:</strong> 
                    <%= user.isAdmin ? 'Administrador' : 'Usuário comum' %>
                    </li>
                </ul>

                <% if (!user.isAdmin) { %>
                    <form action="<%= basePath %>/admin/promote/user/<%= user._id %>" method="post">
                    <button class="btn btn-outline-success w-100">
                        Promover para administrador
                    </button>
                    </form>
                <% } else { %>
                    <button class="btn btn-secondary w-100" disabled>
                    Usuário já é administrador
                    </button>
                <% } %>
            <% } %>

            <a href="<%= basePath %>/admin" class="btn btn-link mt-3">Voltar ao painel</a>
        </div>
    </main>

    <% if (error) { %>
        <script>
            Swal.fire({
                icon: 'warning',
                title: 'Atenção',
                text: '<%= error %>'
            })
        </script>
    <% } %>
    <script src="<%= basePath %>/util/inputmask.js"></script>
</body>
</html>
